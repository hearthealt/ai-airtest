# AI探索性测试配置
# 复制本文件为 config.yaml，填入实际值后使用

# 测试目标（包名 + 小类ID 是一组）
package_name: "tv.danmaku.bili"
l_class: "23921"

# 测试模式: 0=阻断测试（下发阻断规则，验证页面是否被阻断）, 1=功能测试（不下发阻断，验证页面是否正常加载）
mode: 0

# 登录配置（可选，遇到登录界面时自动登录）
login:
  required: true                # 是否需要登录
  phone: "17358607087"          # 登录手机号
  email: ""                     # 登录邮箱
  password: "Test1735860"       # 登录密码
  method: "password"            # password=密码登录, sms=验证码登录, email=邮箱登录

# 设备连接配置
device:
  platform: "Android"
  device_uuid: "your-device-uuid"
  # device_uri: ""         # iOS远程设备用
  # poco_type: ""
  # window_name: ""        # Windows应用用

# AI模型配置
ai:
  api_base_url: "https://apis.iflow.cn/v1"
  api_key: ""                          # 留空则自动从iflow平台获取
  model: "qwen3-vl-plus"
  max_tokens: 4096
  temperature: 0.3
  timeout: 180
  image_max_size: 1280
  image_quality: 70
  max_retries: 3
  # iflow平台自动获取API Key（api_base_url含iflow.cn时生效）
  iflow_name: "173****0061"            # iflow平台账号名称
  iflow_cookies:                       # iflow平台登录cookies
    BXAuth: "your-session-id"

# 探索行为配置
exploration:
  max_steps: 200
  max_duration_seconds: 1800
  max_consecutive_duplicates: 5
  max_errors: 10
  action_delay: 2.0
  max_l2_per_l1: 0               # 每个L1最多测试几个L2；0=不限制，1=只测1个
  similarity_threshold: 0.85

# 路由器阻断规则配置（仅 mode=0 时使用）
router:
  router_host: "192.168.254.122"
  router_port: 22
  router_user: "admin"
  router_pwd: "your-password"
  router_enable_pwd: "your-enable-password"
  extend_device: "t1"

# 输出目录
output_dir: "E:\\tmp\\explore"

# 回放配置
replay_mode: "auto"              # auto=有playbook就回放 / record=强制录制 / replay=强制回放
playbook_dir: ""                 # playbook保存目录（留空默认为项目根目录/playbooks）
